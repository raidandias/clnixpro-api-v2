model InvoiceReceivablePix {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId           String            @db.Uuid
  invoiceReceivableId String            @db.Uuid
  qrCode              String
  reference           String
  linkImage           String?
  linkPix             String?
  linkPage            String?
