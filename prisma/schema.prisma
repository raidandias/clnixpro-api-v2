model Customer {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId          String              @db.Uuid
  userId             String              @db.Uuid
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  account            Account             @relation(fields: [accountId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  invoiceReceivables InvoiceReceivable[]
}

model InvoiceReceivable {
  id                       String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId                String                    @db.Uuid
  orderId                  String                    @db.Uuid
  customerId               String                    @db.Uuid
  authorizationNumber      String?
  installment              Int                       @default(1)
  valueTotal               Decimal                   @default(0.00) @db.Decimal
  valueDiscount            Decimal                   @default(0.00) @db.Decimal
  valueFeesFixed           Decimal                   @default(0.00) @db.Decimal
  valueFeesPercent         Decimal                   @default(0.00) @db.Decimal
  dueAt                    DateTime
  paymentAt                DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  deletedAt                DateTime?
  account                  Account                   @relation(fields: [accountId], references: [id])
  customer                 Customer                  @relation(fields: [customerId], references: [id])
  order                    Order                     @relation(fields: [orderId], references: [id])
  invoicePayments          InvoicePayment[]
  statements               Statement[]
  invoiceReceivableBillets InvoiceReceivableBillet[]
  invoiceReceivablePixs    InvoiceReceivablePix[]
  invoiceReceivableCards   InvoiceReceivableCard[]
}

model InvoicePayable {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId        String           @db.Uuid
  supplierId       String           @db.Uuid
  orderId          String?          @db.Uuid
  valueTotal       Decimal          @default(0.00) @db.Decimal
  valueDiscount    Decimal          @default(0.00) @db.Decimal
  valueFeesFixed   Decimal          @default(0.00) @db.Decimal
  valueFeesPercent Decimal          @default(0.00) @db.Decimal
  dueAt            DateTime
  paymentAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  account          Account          @relation(fields: [accountId], references: [id])
  supplier         Supplier         @relation(fields: [supplierId], references: [id])
  order            Order?           @relation(fields: [orderId], references: [id])
  invoicePayments  InvoicePayment[]
  statements       Statement[]
}

model InvoicePayment {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId            String                @db.Uuid
  invoiceReceivableId  String?               @db.Uuid
  invoicePayableId     String?               @db.Uuid
  descriptionDenied    String?
  valuePayment         Decimal               @default(0.00) @db.Decimal
  valueDiscount        Decimal               @default(0.00) @db.Decimal
  valueFeesFixed       Decimal               @default(0.00) @db.Decimal
  valueFeesPercent     Decimal               @default(0.00) @db.Decimal
  formOfPayment        FormOfPaymentCurrency @default(CASH)
  typeCurrencyExchange TypeCurrencyExchange  @default(BRL)
  paymentAt            DateTime
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  account              Account               @relation(fields: [accountId], references: [id])
  invoiceReceivable    InvoiceReceivable?    @relation(fields: [invoiceReceivableId], references: [id])
  invoicePayable       InvoicePayable?       @relation(fields: [invoicePayableId], references: [id])
  statements           Statement[]
}

model InvoiceReceivableBillet {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
