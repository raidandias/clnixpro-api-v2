model InvoiceReceivableCard {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId           String            @db.Uuid
  invoiceReceivableId String            @db.Uuid
  numberCard          String
  expiresAt           String
  brand               String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?
  account             Account           @relation(fields: [accountId], references: [id])
  InvoiceReceivable   InvoiceReceivable @relation(fields: [invoiceReceivableId], references: [id])
}

model Balance {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId       String   @db.Uuid
  totalReceivable Decimal  @default(0.00) @db.Decimal
  totalPayable    Decimal  @default(0.00) @db.Decimal
  currentBalance  Decimal  @default(0.00) @db.Decimal
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  account         Account  @relation(fields: [accountId], references: [id])
}

model Statement {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId           String             @db.Uuid
  invoiceReceivableId String?            @db.Uuid
  invoicePayableId    String?            @db.Uuid
  invoicePaymentId    String?            @db.Uuid
  amount              Decimal            @default(0.00) @db.Decimal
  transactionType     TransactionType
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  account             Account            @relation(fields: [accountId], references: [id])
  invoiceReceivable   InvoiceReceivable? @relation(fields: [invoiceReceivableId], references: [id])
  invoicePayable      InvoicePayable?    @relation(fields: [invoicePayableId], references: [id])
  invoicePayment      InvoicePayment?    @relation(fields: [invoicePaymentId], references: [id])
}

enum TransactionType {
  RECEIVABLE
  PAYABLE
}
